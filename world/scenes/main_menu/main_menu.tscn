margin_bottom = 514.0
text = "Controller
=========
LStick - Move
RStick - Camera
R3 - Switch Target
Select - Draw/Sheathe
X - Jump
O - Quickstep
[ ] - Interact / Attack
/_\\ - Strong Attack
R1 - Block
R1 -> Lstick - Parry
Quickstep -> R1 - Dash
Dash -> [ ] - Dash Attack
Falling -> [ ] - Falling Attack
"

[node name="Label4" type="Label" parent="."]
anchor_left = 0.5
anchor_right = 0.5
margin_left = -192.0
margin_top = 156.0
margin_right = 187.0
margin_bottom = 657.0
text = "All testing was done in Online > Host, but the other modes should work. I can't express enough how much your support means.

Just hit ` to open the console and view the controls anytime.

If you have a controller connected, you may experience stuttery WASD."
autowrap = true

[node name="Label2" type="Label" parent="."]
