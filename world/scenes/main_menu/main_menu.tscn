text = "Scrubs
=========
WASD - Move
Mouse - Camera
Q - Switch Target
Tab - Draw/Sheathe
Space - Jump
Shift - Quickstep
E/Left Click - Interact / Attack
E - Strong Attack
Right Click - Block
Right Click -> WASD - Parry
Quickstep -> Right Click - Dash
Dash -> Left Click - Dash Attack
Falling -> Left Click - Falling Attack
F11 - Fullscreen"

[node name="Label3" type="Label" parent="."]
